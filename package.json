{
    "name": "django-hstore-widget",
    "description": "Human friendly HStoreWidget. Continual of django-admin-hstore-widget.",
    "repository": {
        "type": "git",
        "url": "https://github.com/baseplate-admin/django-hstore-widget.git"
    },
    "license": "MIT",
    "type": "module",
    "scripts": {
        "build": "vite build && node --experimental-strip-types ./scripts/copy.ts",
        "dev": "vite --port 9100",
        "format": "prettier --write 'src/**/*.ts' 'scripts/**/*.ts'",
        "format:check": "prettier --check 'src/**/*.ts' 'scripts/**/*.ts'",
        "test": "playwright test",
        "test:ui": "playwright test --ui"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "4.7.1",
        "@playwright/test": "^1.60.0",
        "@types/node": "^25.9.3",
        "@typescript/native-preview": "^7.0.0-dev.20260609.1",
        "lit": "^3.3.3",
        "playwright": "^1.51.0",
        "prettier": "3.8.4",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-packagejson": "^3.0.2",
        "vite": "^8.0.16"
    }
}
