#: ../../docs/developer-guide/frontend-build.rst:2
msgid "Frontend Build Pipeline"
msgstr "Конвеєр збірки фронтенду"

#: ../../docs/developer-guide/frontend-build.rst:5
msgid "Overview"
msgstr "Огляд"

#: ../../docs/developer-guide/frontend-build.rst:7
msgid "The widget frontend is built with Vite and TypeScript, producing a single IIFE bundle loaded by Django admin."
msgstr "Фронтенд віджета збирається за допомогою Vite та TypeScript, створюючи один IIFE-бандл, який завантажується Django admin."

#: ../../docs/developer-guide/frontend-build.rst:11
msgid "Build Steps"
msgstr "Етапи збірки"

#: ../../docs/developer-guide/frontend-build.rst:13
msgid "Vite bundles ``src/frontend/index.ts`` into ``dist/components/django-hstore-widget.js``"
msgstr "Vite збирає ``src/frontend/index.ts`` у ``dist/components/django-hstore-widget.js``"

#: ../../docs/developer-guide/frontend-build.rst:14
msgid "``scripts/copy.ts`` copies the bundle to ``src/django_hstore_widget/static/admin/js/django_hstore_widget/``"
msgstr "``scripts/copy.ts`` копіює бандл до ``src/django_hstore_widget/static/admin/js/django_hstore_widget/``"

#: ../../docs/developer-guide/frontend-build.rst:15
msgid "Django serves the bundle via static files"
msgstr "Django надає бандл через статичні файли"

#: ../../docs/developer-guide/frontend-build.rst:18
msgid "Configuration"
msgstr "Конфігурація"

#: ../../docs/developer-guide/frontend-build.rst:20
msgid "``vite.config.ts`` - Entry point, output, aliases, dev server"
msgstr "``vite.config.ts`` — точка входу, вихід, псевдоніми, сервер розробки"

#: ../../docs/developer-guide/frontend-build.rst:21
msgid "``tsconfig.json`` - TypeScript compiler options, path aliases"
msgstr "``tsconfig.json`` — параметри компілятора TypeScript, псевдоніми шляхів"

#: ../../docs/developer-guide/frontend-build.rst:24
msgid "Path Aliases"
msgstr "Псевдоніми шляхів"

#: ../../docs/developer-guide/frontend-build.rst:36
msgid "Resolves to ``src/frontend/lib/*``"
msgstr "Розв'язується до ``src/frontend/lib/*``"

#: ../../docs/developer-guide/frontend-build.rst:45
msgid "Resolves to ``src/frontend/stores/*``"
msgstr "Розв'язується до ``src/frontend/stores/*``"

#: ../../docs/developer-guide/frontend-build.rst:54
msgid "Resolves to ``src/frontend/mappings/*``"
msgstr "Розв'язується до ``src/frontend/mappings/*``"

#: ../../docs/developer-guide/frontend-build.rst:63
msgid "Resolves to ``src/frontend/components/*``"
msgstr "Розв'язується до ``src/frontend/components/*``"

#: ../../docs/developer-guide/frontend-build.rst:66
msgid "Development"
msgstr "Розробка"
