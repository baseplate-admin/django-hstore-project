#: ../../index.rst:2
msgid "Django HStore Project"
msgstr "Проєкт Django HStore"

#: ../../index.rst:4
msgid "A monorepo for the Django HStore ecosystem, human-friendly PostgreSQL hstore support for Django admin."
msgstr "Монорепозиторій для екосистеми Django HStore, зручна підтримка PostgreSQL hstore для адміністративної панелі Django."

#: ../../index.rst:8
msgid "Packages"
msgstr "Пакети"

#: ../../index.rst:13
msgid "django-hstore-widget"
msgstr "django-hstore-widget"

#: ../../index.rst:20
msgid "Custom widget for editing hstore data in Django admin. Built with Lit and TypeScript for a responsive key-value editor."
msgstr "Користувацький віжет для редагування hstore-даних у Django admin. Створено за допомогою Lit та TypeScript для адаптивного редактора пар ключ-значення."

#: ../../index.rst:27
msgid "django-hstore-field"
msgstr "django-hstore-field"

#: ../../index.rst:34
msgid "Drop-in HStoreField with auto-wired widget. Zero configuration for new projects."
msgstr "Готовий HStoreField із автоматично підключеним віджетом. Нульова конфігурація для нових проєктів."

#: ../../index.rst:42
msgid "Quick Start"
msgstr "Швидкий старт"

#: ../../index.rst:44
msgid "For new projects, use **django-hstore-field**:"
msgstr "Для нових проєктів використовуйте **django-hstore-field**:"

#: ../../index.rst:56
msgid "The widget is auto-wired, no form configuration needed."
msgstr "Віджет підключається автоматично, конфігурація форми не потрібна."

