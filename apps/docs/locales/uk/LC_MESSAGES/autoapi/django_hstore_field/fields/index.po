#: ../../autoapi/django_hstore_field/fields/index.rst:2
msgid "django_hstore_field.fields"
msgstr "django_hstore_field.fields"

#: ../../autoapi/django_hstore_field/fields/index.rst:10
msgid "Module Contents"
msgstr "Вміст модуля"

#: ../../autoapi/django_hstore_field/fields/index.rst:14
msgid "Bases: :py:obj:`django.contrib.postgres.fields.HStoreField`"
msgstr "Базові класи: :py:obj:`django.contrib.postgres.fields.HStoreField`"

#: ../../autoapi/django_hstore_field/fields/index.rst:17
msgid "Drop-in replacement for Django's ``HStoreField`` with the custom widget."
msgstr "Готова заміна для ``HStoreField`` Django із користувацьким віджетом."

#: ../../autoapi/django_hstore_field/fields/index.rst:19
msgid "Overrides ``formfield()`` so that the admin and ModelForms automatically use :class:`~django_hstore_widget.forms.HStoreFormField` and :class:`~django_hstore_widget.widgets.HStoreFormWidget` -- no manual form configuration required."
msgstr "Перевизначає ``formfield()``, щоб адміністративна панель та ModelForms автоматично використовували :class:`~django_hstore_widget.forms.HStoreFormField` та :class:`~django_hstore_widget.widgets.HStoreFormWidget` — ручна конфігурація форми не потрібна."

#: ../../autoapi/django_hstore_field/fields/index.rst:25
msgid "Example"
msgstr "Приклад"

#: ../../autoapi/django_hstore_field/fields/index.rst:38
msgid "Return a form field class pre-configured with the custom widget."
msgstr "Повертає клас поля форми, попередньо налаштований із користувацьким віджетом."

#: ../../autoapi/django_hstore_field/fields/index.rst:0
msgid "Parameters"
msgstr "Параметри"

#: ../../autoapi/django_hstore_field/fields/index.rst:40
msgid "Keyword arguments forwarded to the form field constructor. Pass ``form_class`` or ``widget`` to override the defaults."
msgstr "Аргументи з іменами, які передаються до конструктора поля форми. Передайте ``form_class`` або ``widget``, щоб перевизначити значення за замовчуванням."

#: ../../autoapi/django_hstore_field/fields/index.rst:0
msgid "Returns"
msgstr "Повертає"

#: ../../autoapi/django_hstore_field/fields/index.rst:44
msgid "A form field instance wired to the hstore widget."
msgstr "Приклад поля форми, підключений до віджета hstore."

#: ../../autoapi/django_hstore_field/fields/index.rst:0
msgid "Return type"
msgstr "Тип повернення"
