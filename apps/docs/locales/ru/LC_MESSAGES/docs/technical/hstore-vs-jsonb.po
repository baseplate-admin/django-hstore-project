msgid ""
"HStore is more compact because it stores flat key-value pairs without "
"structural overhead:"
msgstr ""
"HStore более компактен, потому что хранит плоские пары ключ-значение без "
"структурных накладных расходов:"

msgid "HStore: ~200 bytes for 10 key-value pairs"
msgstr "HStore: ~200 байт для 10 пар ключ-значение"

msgid "JSONB:  ~350 bytes for the same data (structure overhead)"
msgstr "JSONB: ~350 байт для тех же данных (накладные расходы на структуру)"

msgid "Query Performance"
msgstr "Производительность запросов"

