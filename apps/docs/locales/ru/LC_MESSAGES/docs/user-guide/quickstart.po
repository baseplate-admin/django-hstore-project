msgstr ":doc:`../user-guide/installation` - Подробные варианты установки"

msgid ":doc:`../technical/hstore-vs-jsonb` - When to use HStore vs JSONB"
msgstr ""
":doc:`../technical/hstore-vs-jsonb` - Когда использовать HStore против JSONB"

msgid ":doc:`../user-guide/best-practices` - Tips for production use"
msgstr ""
