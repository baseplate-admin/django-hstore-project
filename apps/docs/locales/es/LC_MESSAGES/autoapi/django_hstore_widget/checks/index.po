msgid "django_hstore_widget.checks"
msgstr "django_hstore_widget.checks"

#: ../../autoapi/django_hstore_widget/checks/index.rst:10
msgid "Module Contents"
msgstr "Contenido del Módulo"

#: ../../autoapi/django_hstore_widget/checks/index.rst:14
msgid "System check that warns when the default DB backend is not PostgreSQL."
msgstr "Verificación del sistema que advierte cuando el backend de base de datos predeterminado no es PostgreSQL."

#: ../../autoapi/django_hstore_widget/checks/index.rst:16
msgid "HStore requires the ``hstore`` extension, which is only available on PostgreSQL.  This check runs during ``manage.py check`` and ``manage.py migrate``."
msgstr "HStore requiere la extensión ``hstore``, que solo está disponible en PostgreSQL. Esta verificación se ejecuta durante ``manage.py check`` y ``manage.py migrate``."

#: ../../autoapi/django_hstore_widget/checks/index.rst:0
msgid "Parameters"
msgstr "Parámetros"

#: ../../autoapi/django_hstore_widget/checks/index.rst:20
msgid "The application configurations being checked."
msgstr "Las configuraciones de aplicación que se están verificando."

#: ../../autoapi/django_hstore_widget/checks/index.rst:22
msgid "Additional keyword arguments from the check runner."
msgstr "Argumentos de palabra clave adicionales del ejecutor de verificaciones."

#: ../../autoapi/django_hstore_widget/checks/index.rst:0
msgid "Returns"
msgstr "Retorna"

#: ../../autoapi/django_hstore_widget/checks/index.rst:24
msgid "A list containing a warning if the default database engine does not include ``postgres`` or ``postgis``."
msgstr "Una lista que contiene una advertencia si el motor de base de datos predeterminado no incluye ``postgres`` ni ``postgis``."

#: ../../autoapi/django_hstore_widget/checks/index.rst:0
msgid "Return type"
msgstr "Tipo de retorno"
