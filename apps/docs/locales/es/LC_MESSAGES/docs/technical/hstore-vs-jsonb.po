msgid "HStore: ~200 bytes for 10 key-value pairs"
msgstr "HStore: ~200 bytes para 10 pares clave-valor"

msgid "JSONB:  ~350 bytes for the same data (structure overhead)"
msgstr "JSONB: ~350 bytes para los mismos datos (sobrecarga de estructura)"

