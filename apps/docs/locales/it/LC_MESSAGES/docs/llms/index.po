msgid "LLM Context Files"
msgstr "File di Contesto per LLM"

#: ../../docs/llms/index.rst:4
msgid ""
"This project provides machine-readable context files for LLM integration, "
"auto-generated during the Sphinx documentation build."
msgstr ""
"Questo progetto fornisce file di contesto leggibili da macchina per "
"l'integrazione con LLM, generati automaticamente durante la build della "
"documentazione Sphinx."

