msgstr ":doc:`../user-guide/installation` - Opções de instalação detalhadas"

msgid ":doc:`../technical/hstore-vs-jsonb` - When to use HStore vs JSONB"
msgstr ":doc:`../technical/hstore-vs-jsonb` - Quando usar HStore vs JSONB"

msgid ":doc:`../user-guide/best-practices` - Tips for production use"
msgstr ":doc:`../user-guide/best-practices` - Dicas para uso em produção"
