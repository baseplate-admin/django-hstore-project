msgid "django_hstore_widget.forms"
msgstr "django_hstore_widget.forms"

msgid "Module Contents"
msgstr "Conteúdo do módulo"

msgid "Bases: :py:obj:`django.contrib.postgres.forms.HStoreField`"
msgstr "Bases: :py:obj:`django.contrib.postgres.forms.HStoreField`"

msgid ""
"Form field that uses "
":class:`~django_hstore_widget.widgets.HStoreFormWidget`."
msgstr ""
"Campo de formulário que usa "
":class:`~django_hstore_widget.widgets.HStoreFormWidget`."

msgid ""
"Extends Django's built-in ``HStoreField`` to inject the custom widget and "
"override ``clean()`` so incoming values are parsed through ``json.loads``."
msgstr ""
"Estende o ``HStoreField`` integrado do Django para injetar o widget "
"personalizado e substituir ``clean()`` para que valores recebidos sejam "
"analisados através de ``json.loads``."

msgid "Example"
msgstr "Exemplo"

msgid "Parse the raw form value into a Python dict."
msgstr "Analisar o valor bruto do formulário em um dict Python."

msgid "Parameters"
msgstr "Parâmetros"

msgid "The raw value submitted by the form."
msgstr "O valor bruto enviado pelo formulário."

msgid "Returns"
msgstr "Retorna"

msgid "The deserialized key-value mapping."
msgstr "O mapeamento chave-valor desserializado."

msgid "Return type"
msgstr "Tipo de retorno"
