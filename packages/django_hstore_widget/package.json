{
    "name": "django-hstore-widget",
    "description": "Human friendly HStoreWidget. Continual of django-admin-hstore-widget.",
    "repository": {
        "type": "git",
        "url": "https://github.com/baseplate-admin/django-hstore-widget.git"
    },
    "license": "MIT",
    "type": "module",
    "scripts": {
        "build": "node --experimental-strip-types ./node_modules/webpack-cli/bin/cli.js --disable-interpret --config webpack.config.ts --mode production && node --experimental-strip-types ./scripts/copy.ts",
        "dev": "node --experimental-strip-types ./node_modules/webpack-cli/bin/cli.js --disable-interpret serve --config webpack.config.ts --mode development --port 9100",
        "format": "prettier --write 'src/**/*.ts' 'scripts/**/*.ts'",
        "format:check": "prettier --check 'src/**/*.ts' 'scripts/**/*.ts'",
        "test": "playwright test",
        "test:jest": "node ./node_modules/jest/bin/jest.js --config jest.config.cjs",
        "test:ui": "playwright test --ui",
        "typecheck": "tsc --noEmit",
        "tsgo": "tsgo --noEmit"
    },
    "devDependencies": {
        "@babel/core": "^7.26.0",
        "@babel/plugin-proposal-decorators": "^7.29.7",
        "@babel/plugin-syntax-import-attributes": "^7.29.7",
        "@babel/plugin-transform-class-properties": "^7.29.7",
        "@babel/plugin-transform-private-methods": "^7.29.7",
        "@babel/preset-env": "^7.26.0",
        "@babel/preset-typescript": "^7.26.0",
        "@ianvs/prettier-plugin-sort-imports": "4.7.1",
        "@playwright/test": "^1.60.0",
        "@types/jest": "^29.5.0",
        "@types/node": "^25.9.3",
        "@typescript/native-preview": "^7.0.0-dev.20260612.1",
        "babel-jest": "^30.4.1",
        "babel-loader": "^9.2.0",
        "esbuild": "^0.28.1",
        "esbuild-register": "^3.6.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "lit": "^3.3.3",
        "playwright": "^1.51.0",
        "prettier": "3.8.4",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-packagejson": "^3.0.2",
        "raw-loader": "^4.0.2",
        "terser-webpack-plugin": "^5.6.1",
        "ts-loader": "^9.6.0",
        "tslib": "^2.8.0",
        "webpack": "^5.97.0",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.0"
    },
    "allowScripts": {
        "esbuild@0.28.1": true
    }
}
