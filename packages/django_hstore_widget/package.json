{
    "name": "django-hstore-widget",
    "description": "Human friendly HStoreWidget. Continual of django-admin-hstore-widget.",
    "repository": {
        "type": "git",
        "url": "https://github.com/baseplate-admin/django-hstore-widget.git"
    },
    "license": "MIT",
    "type": "module",
    "scripts": {
        "build": "vite build && node --experimental-strip-types ./scripts/copy.ts",
        "dev": "vite",
        "preview": "vite preview",
        "format": "prettier --write 'src/**/*.ts' 'scripts/**/*.ts'",
        "format:check": "prettier --check 'src/**/*.ts' 'scripts/**/*.ts'",
        "test": "vitest run",
        "test:unit": "vitest run",
        "test:ui": "vitest",
        "tsgo": "tsgo --noEmit",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "4.7.1",
        "@playwright/test": "^1.61.1",
        "@types/node": "^26.1.1",
        "@typescript/native-preview": "^7.0.0-dev.20260706.1",
        "@vitest/browser": "^4.1.9",
        "@vitest/browser-playwright": "^4.1.10",
        "lightningcss": "^1.33.0",
        "lit": "^3.3.3",
        "lucide": "^1.26.0",
        "lucide-static": "^1.25.0",
        "playwright": "^1.51.0",
        "prettier": "3.9.6",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-packagejson": "^3.0.2",
        "tslib": "^2.8.0",
        "typescript": "^7.0.2",
        "vite": "^8.1.5",
        "vitest": "^4.1.10"
   }
}
