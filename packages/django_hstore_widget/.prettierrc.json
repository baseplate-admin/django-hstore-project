{
    "plugins": ["prettier-plugin-organize-imports", "prettier-plugin-packagejson"],
    "arrowParens": "avoid",
    "bracketSpacing": true,
    "jsxBracketSameLine": false,
    "jsxSingleQuote": false,
    "quoteProps": "consistent",
    "printWidth": 180,
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "all",
    "useTabs": false
}
